# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/deployment-panel

# Redis connection (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Express server port
PORT=3001

# AWS credentials (for SSM + Lambda)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# EC2 instance ID (for SSM SendCommand)
EC2_INSTANCE_ID=i-0123456789abcdef0

# Lambda function name to invoke after deployment
LAMBDA_FUNCTION_NAME=post-deployment-setup
